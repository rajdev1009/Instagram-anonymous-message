# 1. Neon DB se Connection String copy karo → neon.tech
DATABASE_URL="postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require"

# 2. Google Console se lao → console.cloud.google.com
GOOGLE_CLIENT_ID="123456789-abc.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your_secret_here"

# 3. Terminal mein run karo: openssl rand -base64 32
NEXTAUTH_SECRET="paste_openssl_output_here"

# 4. Local ke liye localhost, production mein apna domain dalo
NEXTAUTH_URL="http://localhost:3000"

